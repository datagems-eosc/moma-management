# NEO4J CONFIG
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=datagems

MAPPING_FILE=moma_management/domain/mapping.yml

# Reverse proxy configuration
ROOT_PATH=/

# AUTH configuration
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_EXCHANGE_SCOPE=
JWKS_TTL_SECONDS=300
PERMISSIONS_GATEWAY_URL=

# Semantic search
EMBEDDER_MODEL=all-MiniLM-L6-v2

# Profiling (set to true to enable request profiling middleware)
PROFILING=false

# OpenTelemetry (zero-code auto-instrumentation)
OTEL_SERVICE_NAME=moma-management
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=