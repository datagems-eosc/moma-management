{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "MoMaGraphModel",
    "type": "object",
    "properties": {
        "nodes": {
            "type": "array",
            "items": {
                "$ref": "nodes/node.schema.json"
            }
        },
        "edges": {
            "type": "array",
            "items": {
                "$ref": "edges/edge.schema.json"
            }
        }
    },
    "required": ["nodes"]
}
