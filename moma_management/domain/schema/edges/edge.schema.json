{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Edge",
    "$defs": {
        "EdgeLabel": {
            "title": "EdgeLabel",
            "type": "string",
            "enum": [
                "distribution",
                "recordSet",
                "linkTo",
                "containedIn",
                "field",
                "source/fileObject",
                "source/fileSet",
                "statistics",
                "intervalStatistics",
                "consist_of",
                "input",
                "output",
                "follows",
                "uses",
                "is_accomplished_by",
                "perform_inference",
                "is_measured_by",
                "fitted_on",
                "trained_on",
                "VIRTUAL_BELONGS_TO",
                "HAS_COMPARISON",
                "HAS_EVIDENCE",
                "HAS_TARGET"
            ]
        }
    },
    "type": "object",
    "properties": {
        "from": {
            "type": "string",
            "description": "ID of the source node",
            "format": "uuid"
        },
        "to": {
            "type": "string",
            "description": "ID of the target node",
            "format": "uuid"
        },
        "labels": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/EdgeLabel"
            },
            "description": "Edge type labels (e.g. distribution, field, statistics)"
        },
        "properties": {
            "type": ["object", "null"],
            "description": "Additional edge properties",
            "properties": {
                "mapping": {
                    "type": [
                        "object",
                        "null"
                    ],
                    "description": "Data-flow mapping; keys are target parameter names, values are JSONPath-from expressions (e.g. \"from['x']\")",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "weight": {
                    "type": ["number", "null"],
                    "description": "HAS_COMPARISON: weight of this PropertyComparison in the BasicDLElement's similarity computation"
                },
                "rank": {
                    "type": ["integer", "null"],
                    "description": "HAS_EVIDENCE: importance ranking of this TextEvidence within its PropertyComparison"
                },
                "chunk": {
                    "type": ["string", "null"],
                    "description": "HAS_TARGET: the specific chunk of text/value looked into the target dataset"
                },
                "similarityScore": {
                    "type": ["number", "null"],
                    "description": "HAS_TARGET (on PropertyComparison/TextEvidence edges): similarity value computed against this specific target dataset"
                }
            },
            "propertyNames": {
                "pattern": "^[a-z@][a-zA-Z0-9_]*$"
            }
        }
    },
    "required": [
        "from",
        "to",
        "labels"
    ],
    "$id": "edges/edge.schema.json"
}
