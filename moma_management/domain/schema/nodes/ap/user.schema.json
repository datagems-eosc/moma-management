{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "nodes/ap/user.schema.json",
    "title": "User",
    "description": "A User node embedded inside an AnalyticalPattern subgraph to record which user triggered or configured a specific Operator.",
    "$defs": {
        "pgProperties": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Display name of the user"
                },
                "email": {
                    "type": "string",
                    "format": "email",
                    "description": "User email address"
                },
                "role": {
                    "type": "string",
                    "description": "Role of the user within the system"
                }
            },
            "unevaluatedProperties": false
        }
    }
}