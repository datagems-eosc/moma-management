{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "systemEvaluation.schema.json",
    "title": "System Evaluation",
    "allOf": [
        {
            "$ref": "evaluation.schema.json"
        }
    ],
    "type": "object",
    "description": "An immutable snapshot of quality metrics collected for one execution of an AnalyticalPattern",
    "labels": {
        "type": "array",
        "items": {
            "type": "string"
        },
        "default": [
            "Evaluation",
            "SystemEvaluation"
        ],
        "allOf": [
            {
                "contains": {
                    "const": "Evaluation"
                }
            },
            {
                "contains": {
                    "const": "SystemEvaluation"
                }
            }
        ]
    },
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "SystemEvaluation"
            ],
            "default": "SystemEvaluation"
        }
    }
}