{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "nodes/ap/evaluation.schema.json",
    "title": "Evaluation",
    "description": "An immutable snapshot of quality metrics collected for one execution of an AnalyticalPattern",
    "$defs": {
        "pgProperties": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "SystemEvaluation",
                        "DataEvaluation",
                        "HumanEvaluation",
                        "EcologicalEvaluation"
                    ],
                    "description": "Evaluation dimension that determines the sub-label (e.g. SystemEvaluation)"
                },
                "executionId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique identifier for this evaluation run"
                },
                "evaluation": {
                    "type": "string",
                    "description": "The JSON-encoded evaluation data"
                }
            },
            "required": [
                "executionId",
                "evaluation"
            ],
            "unevaluatedProperties": false
        }
    }
}