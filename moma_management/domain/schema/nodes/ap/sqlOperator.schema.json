{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "nodes/ap/sqlOperator.schema.json",
    "title": "SQL_Operator",
    "description": "An Operator that executes a SQL statement. Carries the SQL query and metadata about the query type.",
    "$defs": {
        "pgProperties": {
            "allOf": [
                {
                    "$ref": "operator.schema.json#/$defs/pgProperties"
                },
                {
                    "type": "object",
                    "properties": {
                        "query": {
                            "type": "string",
                            "description": "The SQL query string (may contain template placeholders)"
                        },
                        "queryType": {
                            "type": "string",
                            "description": "SQL verb (e.g. SELECT, INSERT, UPDATE, DELETE)"
                        }
                    }
                }
            ],
            "unevaluatedProperties": false
        }
    }
}