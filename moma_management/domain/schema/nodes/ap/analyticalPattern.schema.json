{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "nodes/ap/analyticalPattern.schema.json",
    "title": "Analytical_Pattern",
    "description": "Root node of an AnalyticalPattern subgraph. Identifies a reusable analytical workflow composed of Operators.",
    "$defs": {
        "pgProperties": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Human-readable name of the analytical pattern"
                },
                "description": {
                    "type": "string",
                    "description": "What the pattern does"
                },
                "process": {
                    "type": "string",
                    "description": "High-level process category (e.g. query, transform)"
                },
                "publishedDate": {
                    "type": "string",
                    "format": "date",
                    "description": "Date the pattern was published"
                },
                "startTime": {
                    "type": "string",
                    "description": "Optional start time for execution scheduling"
                }
            },
            "required": [
                "name"
            ],
            "unevaluatedProperties": false
        }
    }
}