{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "nodes/ap/operator.schema.json",
    "title": "Operator",
    "description": "An Operator node represents a single processing step within an AnalyticalPattern. Specialisations (e.g. SQL_Operator) add further properties.",
    "$defs": {
        "parameterItem": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Parameter name"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "string",
                        "boolean",
                        "number",
                        "array",
                        "object"
                    ],
                    "description": "JSON Schema type"
                },
                "required": {
                    "type": "boolean",
                    "default": true
                },
                "default": {}
            },
            "required": [
                "name",
                "type"
            ]
        },
        "pgProperties": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "The Croissant/domain @type value for this operator"
                },
                "publishedDate": {
                    "type": "string",
                    "format": "date",
                    "description": "Date the operator was published (ISO 8601: YYYY-MM-DD)"
                },
                "name": {
                    "type": "string",
                    "description": "Human-readable name of the operator"
                },
                "description": {
                    "type": "string",
                    "description": "What this operator does"
                },
                "version": {
                    "type": "string",
                    "description": "Operator version string"
                },
                "command": {
                    "type": "string",
                    "description": "Executable command or function name"
                },
                "step": {
                    "type": "integer",
                    "description": "Ordinal position in the operator sequence"
                },
                "startTime": {
                    "type": "string",
                    "description": "Optional operator-level start time"
                },
                "inputs": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/parameterItem"
                    },
                    "description": "Typed input parameters"
                },
                "outputs": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/parameterItem"
                    },
                    "description": "Typed output parameters"
                }
            },
            "required": [
                "name"
            ]
        }
    }
}