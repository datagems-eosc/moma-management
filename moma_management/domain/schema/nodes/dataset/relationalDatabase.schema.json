{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "RelationalDatabase",
    "$defs": {
        "pgProperties": {
            "allOf": [
                {
                    "$ref": "structuredData.schema.json#/$defs/pgProperties"
                },
                {
                    "type": "object",
                    "properties": {
                        "connectionString": {
                            "type": "string",
                            "description": "Database connection string"
                        },
                        "engine": {
                            "type": "string",
                            "description": "Database engine (PostgreSQL, MySQL, etc)"
                        }
                    }
                }
            ],
            "unevaluatedProperties": false
        }
    },
    "$id": "nodes/dataset/relationalDatabase.schema.json"
}