{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "nodes/dataset/column.schema.json",
    "title": "Column",
    "$defs": {
        "pgProperties": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Column name"
                },
                "description": {
                    "type": "string",
                    "description": "Description of the column content"
                },
                "dataType": {
                    "type": "string",
                    "description": "Data type of the column"
                },
                "column": {
                    "type": "string",
                    "description": "Column identifier within the source file"
                },
                "sample": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Sample values from the column"
                }
            },
            "unevaluatedProperties": false
        }
    }
}