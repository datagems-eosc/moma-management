{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "PdfSet",
    "$defs": {
        "pgProperties": {
            "allOf": [
                {
                    "$ref": "unstructuredData.schema.json#/$defs/pgProperties"
                },
                {
                    "type": "object",
                    "properties": {
                        "subject": {
                            "type": "string",
                            "description": "Subject or topic of the PDF"
                        },
                        "author": {
                            "type": "string",
                            "description": "Author of the document"
                        },
                        "title": {
                            "type": "string",
                            "description": "Title of the PDF"
                        },
                        "producer": {
                            "type": "string",
                            "description": "Software used to produce the PDF"
                        },
                        "creator": {
                            "type": "string",
                            "description": "Original application that created the document"
                        },
                        "creationDate": {
                            "type": "string",
                            "description": "Date the PDF was originally created"
                        },
                        "modificationDate": {
                            "type": "string",
                            "description": "Date the PDF was last modified"
                        },
                        "pagesCount": {
                            "type": "integer",
                            "description": "Total number of pages"
                        },
                        "keywords": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Keywords associated with the PDF"
                        },
                        "summary": {
                            "type": "string",
                            "description": "Summary of the PDF content"
                        }
                    }
                }
            ],
            "unevaluatedProperties": false
        }
    },
    "$id": "nodes/dataset/pdfSet.schema.json"
}