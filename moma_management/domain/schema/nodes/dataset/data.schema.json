{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Data",
    "$defs": {
        "pgProperties": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "The Croissant @type value (e.g. cr:FileObject, cr:FileSet)"
                },
                "name": {
                    "type": "string",
                    "description": "Human-readable name of the data node"
                },
                "description": {
                    "type": "string",
                    "description": "Description of the data content"
                },
                "contentUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL where the data can be accessed"
                },
                "contentSize": {
                    "type": "string",
                    "description": "Size of the content (e.g. '154411 B')"
                },
                "encodingFormat": {
                    "type": "string",
                    "description": "MIME type of the content (e.g. 'text/csv')"
                },
                "sha256": {
                    "type": "string",
                    "description": "SHA-256 checksum of the content"
                }
            }
        }
    },
    "$id": "nodes/dataset/data.schema.json"
}