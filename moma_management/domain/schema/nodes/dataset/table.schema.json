{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "nodes/dataset/table.schema.json",
    "title": "Table",
    "$defs": {
        "pgProperties": {
            "allOf": [
                {
                    "$ref": "data.schema.json#/$defs/pgProperties"
                },
                {
                    "type": "object",
                    "properties": {
                        "primaryKey": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Primary key column name(s)"
                        },
                        "foreignKey": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Foreign key column name(s)"
                        }
                    }
                }
            ],
            "unevaluatedProperties": false
        }
    }
}