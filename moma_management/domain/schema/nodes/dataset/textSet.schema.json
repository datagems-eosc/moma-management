{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "TextSet",
    "$defs": {
        "pgProperties": {
            "allOf": [
                {
                    "$ref": "unstructuredData.schema.json#/$defs/pgProperties"
                },
                {
                    "type": "object",
                    "properties": {
                        "summary": {
                            "type": "string",
                            "description": "A summary of the text file"
                        },
                        "keywords": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Key terms or phrases extracted from the text"
                        },
                        "language": {
                            "type": "string",
                            "description": "The detected primary language"
                        },
                        "numLines": {
                            "type": "integer",
                            "description": "Total number of lines"
                        },
                        "numWords": {
                            "type": "integer",
                            "description": "Total number of words"
                        },
                        "numCharacters": {
                            "type": "integer",
                            "description": "Total number of characters"
                        },
                        "avgSentenceLength": {
                            "type": "number",
                            "description": "Average number of words per sentence"
                        },
                        "numParagraphs": {
                            "type": "integer",
                            "description": "Total number of paragraphs"
                        },
                        "fleschKincaidGrade": {
                            "type": "number",
                            "description": "Flesch-Kincaid readability grade level"
                        }
                    }
                }
            ],
            "unevaluatedProperties": false
        }
    },
    "$id": "nodes/dataset/textSet.schema.json"
}