{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Node",
    "type": "object",
    "description": "A PG-JSON node in the MoMa graph. The 'labels' array identifies the MoMa type(s), and 'properties' holds all node attributes.",
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique identifier of the node",
            "format": "uuid",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
        },
        "labels": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Node type labels (e.g. Dataset, CSV, Column)"
        },
        "properties": {
            "type": "object",
            "description": "Node attributes as defined by the MoMa node type",
            "additionalProperties": true,
            "propertyNames": {
                "pattern": "^[a-z@][a-zA-Z0-9_]*$"
            }
        }
    },
    "required": [
        "id",
        "labels",
        "properties"
    ],
    "allOf": [
        {
            "if": {
                "properties": {
                    "labels": {
                        "contains": {
                            "const": "sc:Dataset"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "properties": {
                        "$ref": "dataset/dataset.schema.json#/$defs/pgProperties"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "labels": {
                        "contains": {
                            "const": "Data"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "properties": {
                        "$ref": "dataset/data.schema.json#/$defs/pgProperties"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "labels": {
                        "contains": {
                            "const": "RelationalDatabase"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "properties": {
                        "$ref": "dataset/relationalDatabase.schema.json#/$defs/pgProperties"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "labels": {
                        "contains": {
                            "const": "CsvSet"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "properties": {
                        "$ref": "dataset/csvSet.schema.json#/$defs/pgProperties"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "labels": {
                        "contains": {
                            "const": "TextSet"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "properties": {
                        "$ref": "dataset/textSet.schema.json#/$defs/pgProperties"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "labels": {
                        "contains": {
                            "const": "PDFSet"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "properties": {
                        "$ref": "dataset/pdfSet.schema.json#/$defs/pgProperties"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "labels": {
                        "contains": {
                            "const": "VideoSet"
                        }
                    }
                }
            },
            "then": {
                "properties": {
